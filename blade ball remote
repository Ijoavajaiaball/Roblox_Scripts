-- Find Active Ball Engine
local function getActiveBall()
    -- Dynamic tracking fallback looking for typical custom ball group folders
    local ballsFolder = workspace:FindFirstChild("Balls")
    if ballsFolder then
        for _, ball in ipairs(ballsFolder:GetChildren()) do
            if ball:GetAttribute("realBall") == true or ball.Name:lower():find("ball") then
                return ball
            end
        end
    end
    -- Ultimate fallback scan of baseline workspace
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj.Name:lower():find("ball") and obj:IsA("BasePart") then
            return obj
        end
    end
    return nil
end

-- Execute Remote Network Parry Injection
local function fireParryRemote()
    -- Look for the parry remote event across game directory structures safely
    local parryRemote = ReplicatedStorage:FindFirstChild("Parry") or 
                        ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ParryAttempt")
    
    if parryRemote and parryRemote:IsA("RemoteEvent") then
        parryRemote:FireServer()
    else
        -- Absolute engine backup simulation action block
        local virtualUser = game:GetService("VirtualUser")
        virtualUser:ClickButton1(Vector2.new(0, 0))
    end
end

-- Continuous Physics Calculation Core Hook
RunService.PostSimulation:Connect(function()
    if not Config.AutoParry then return end
    
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local ball = getActiveBall()
    if ball then
        local ballPosition = ball.Position
        local ballVelocity = ball.AssemblyLinearVelocity
        local playerPosition = rootPart.Position
        
        -- Vector parsing to calculate target paths
        local distance = (ballPosition - playerPosition).Magnitude
        local directionToPlayer = (playerPosition - ballPosition).Unit
        local velocityTowardsPlayer = ballVelocity:Dot(directionToPlayer)
        
        if velocityTowardsPlayer > 0 then
            -- TTI Equation: Time = Distance / Speed
            local timeToImpact = distance / velocityTowardsPlayer
            
            -- Trigger block if ball hits reaction threshold or drops below safe range limits
            if timeToImpact <= Config.ReactionTime or distance <= Config.ParryRange then
                fireParryRemote()
            end
        end
    end
end)
