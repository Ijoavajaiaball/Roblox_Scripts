-- [[ TITANIUM HUB: BLADE BALL AUTO-PARRY ]]
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

-- Locate the Parry Remote (Blade Ball frequently obfuscates or changes these)
-- Common remotes: "ParryAttempt", "Parry", "Block", or an Argument inside a generic Remote
local ParryRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ParryAttempt") 
    or ReplicatedStorage:FindFirstChild("ParryAttempt") 
    or ReplicatedStorage:FindFirstChild("Parry")

local function getBall()
    -- Look through the workspace for the active ball object
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj.Name == "Ball" or obj:FindFirstChild("BallScript") or obj:GetAttribute("Ball") then
            return obj
        end
    end
    return nil
end

-- Active Auto-Parry Loop
local AutoParryConnection
AutoParryConnection = RunService.Heartbeat:Connect(function()
    local ball = getBall()
    if not ball or not Character:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = Character.HumanoidRootPart
    local ballPosition = ball.Position
    local playerPosition = hrp.Position
    
    -- Calculate distance between you and the ball
    local distance = (ballPosition - playerPosition).Magnitude
    
    -- Check ball's velocity vector to see if it's moving towards you
    local ballVelocity = ball.AssemblyLinearVelocity
    local directionToPlayer = (playerPosition - ballPosition).Unit
    local dotProduct = ballVelocity.Unit:Dot(directionToPlayer)
    
    -- Target detection: Adjust target distance based on ball speed (dynamic scaling)
    local currentBallSpeed = ballVelocity.Magnitude
    local parryThreshold = math.clamp(currentBallSpeed * 0.4, 15, 45) -- Dynamically scales parry window
    
    -- If ball is moving toward us and is within the dynamic threshold, fire the remote
    if dotProduct > 0.35 and distance <= parryThreshold then
        if ParryRemote then
            -- Standard Blade Ball remote signature requires a vector or boolean context
            ParryRemote:FireServer(true, ballPosition)
        end
    end
end)

-- Clean up connection on death
Character:FindFirstChildOfClass("Humanoid").Died:Connect(function()
    if AutoParryConnection then AutoParryConnection:Disconnect() end
end)
